# =============================================================================
# Unreal Engine 5 — .editorconfig (범용 템플릿)
# 사용법: 프로젝트 루트에 복사
# Visual Studio / VS Code / Rider 에서 자동 적용
# =============================================================================

root = true

# =============================================================================
# 전체 기본값
# =============================================================================
[*]
charset                  = utf-8
end_of_line              = lf
insert_final_newline     = true
trim_trailing_whitespace = true

# =============================================================================
# C++ 소스 — UE5 코딩 컨벤션
# https://dev.epicgames.com/documentation/en-us/unreal-engine/coding-standard
# =============================================================================
[*.{cpp,h,inl,usf,ush}]
end_of_line              = crlf
indent_style             = tab
indent_size              = 4
tab_width                = 4

# =============================================================================
# C# (Build scripts: .Target.cs, .Build.cs)
# =============================================================================
[*.cs]
end_of_line              = crlf
indent_style             = tab
indent_size              = 4
tab_width                = 4

# =============================================================================
# 설정 파일
# =============================================================================
[*.ini]
indent_style             = space
indent_size              = 2

[*.{json,yaml,yml}]
indent_style             = space
indent_size              = 2

# =============================================================================
# 마크다운
# =============================================================================
[*.md]
trim_trailing_whitespace = false

# =============================================================================
# Unreal Engine 5 — .gitattributes (범용 템플릿)
# 사용법: 프로젝트 루트에 복사
# =============================================================================

# 기본 동작: 텍스트 파일 줄바꿈 자동 정규화
* text=auto

# =============================================================================
# UE5 바이너리 에셋 — diff/merge/줄바꿈 변환 완전 비활성
# =============================================================================
*.uasset    binary
*.umap      binary
*.uassetmeta binary
*.uplugin   binary
*.uproject  binary

# 컴파일된 쉐이더 / 캐시
*.ushaderbytecode binary
*.upipelinecache  binary

# 패키지 / 아카이브
*.pak   binary
*.ucas  binary
*.utoc  binary
*.ubulk binary

# 이미지
*.png   binary
*.tga   binary
*.jpg   binary
*.jpeg  binary
*.bmp   binary
*.tif   binary
*.tiff  binary
*.hdr   binary
*.exr   binary
*.dds   binary

# 오디오
*.wav   binary
*.mp3   binary
*.ogg   binary
*.aif   binary
*.aiff  binary

# 비디오
*.mp4   binary
*.mov   binary
*.avi   binary

# 3D 메시
*.fbx   binary
*.obj   binary
*.3ds   binary

# 폰트
*.ttf   binary
*.otf   binary

# 압축
*.zip   binary
*.7z    binary
*.rar   binary

# =============================================================================
# UE5 / C++ 소스 — CRLF (Windows 기준)
# =============================================================================
*.cpp       text eol=crlf
*.h         text eol=crlf
*.cs        text eol=crlf
*.inl       text eol=crlf
*.usf       text eol=crlf
*.ush       text eol=crlf

# =============================================================================
# 설정 / 마크업 — LF 통일
# =============================================================================
*.ini       text eol=lf
*.json      text eol=lf
*.xml       text eol=lf
*.yaml      text eol=lf
*.yml       text eol=lf
*.md        text eol=lf
*.txt       text eol=lf
*.cfg       text eol=lf
.gitignore  text eol=lf
.gitattributes text eol=lf
